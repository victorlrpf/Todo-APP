<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:models="clr-namespace:TodoApp.Models"
             x:Class="TodoApp.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Registrador de Tarefas"
             BackgroundColor="#F8F6F0">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- Header com Contadores -->
            <Grid BackgroundColor="#512BD4" Padding="20,30,20,20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📋 Minhas Tarefas"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <HorizontalStackLayout Spacing="20">
                        <VerticalStackLayout>
                            <Label Text="{Binding TotalTasks}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label Text="Total"
                                   FontSize="12"
                                   TextColor="#D4C6FF" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="{Binding CompletedTasks}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#10B981" />
                            <Label Text="Concluídas"
                                   FontSize="12"
                                   TextColor="#D4C6FF" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="{Binding PendingTasks}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#FFC107" />
                            <Label Text="Pendentes"
                                   FontSize="12"
                                   TextColor="#D4C6FF" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <!-- Seção de Categorias (Abas) -->
            <VerticalStackLayout Padding="16,16,16,8" Spacing="10">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Categorias"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           VerticalOptions="Center" />
                    <Button Text="+"
                            FontSize="16"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="#512BD4"
                            TextColor="White"
                            Command="{Binding ToggleAddCategoryCommand}"
                            VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Formulário de Nova Categoria (visível quando IsAddingCategory = true) -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="#E0E0E0"
                        BackgroundColor="White"
                        Padding="12"
                        IsVisible="{Binding IsAddingCategory}">
                    <VerticalStackLayout Spacing="8">
                        <Entry Placeholder="Nome da categoria"
                               Text="{Binding NewCategoryName}"
                               FontSize="14" />
                        <HorizontalStackLayout Spacing="8">
                            <Entry Placeholder="Emoji (ex: 🎯)"
                                   Text="{Binding NewCategoryIcon}"
                                   WidthRequest="80"
                                   FontSize="14" />
                            <Button Text="Criar Categoria"
                                    Command="{Binding AddCategoryCommand}"
                                    BackgroundColor="#10B981"
                                    TextColor="White"
                                    FontSize="13"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    HorizontalOptions="FillAndExpand" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Lista de Categorias como Chips -->
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeShape="RoundRectangle 20"
                                Stroke="#512BD4"
                                BackgroundColor="{Binding SelectedFilterCategory, Converter={StaticResource NullToBgConverter}}"
                                Padding="12,8"
                                HeightRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowAllTasksCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="📋 Todas"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#512BD4"
                                   VerticalOptions="Center" />
                        </Border>
                        <CollectionView ItemsSource="{Binding Categories}"
                                        ItemsLayout="HorizontalList"
                                        HeightRequest="40">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Category">
                                    <Border StrokeShape="RoundRectangle 20"
                                            Stroke="{Binding Color}"
                                            BackgroundColor="White"
                                            Padding="12,8"
                                            Margin="0,0,8,0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=FilterByCategoryCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label FontSize="13"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Icon}" />
                                                    <Span Text=" " />
                                                    <Span Text="{Binding Name}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- Formulário de Nova Tarefa -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="#E0E0E0"
                    BackgroundColor="White"
                    Padding="16"
                    Margin="16,8,16,8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Nova Tarefa"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#333333" />
                    <Entry Placeholder="O que você precisa fazer?"
                           Text="{Binding NewTaskName}"
                           FontSize="15"
                           BackgroundColor="#F5F5F5"
                           Margin="0" />
                    <Entry Placeholder="Descrição (opcional)"
                           Text="{Binding NewTaskDescription}"
                           FontSize="14"
                           BackgroundColor="#F5F5F5"
                           Margin="0" />
                    <Picker Title="Selecionar Categoria"
                            ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCategoryForNewTask}"
                            FontSize="14" />
                    <Button Text="＋ Adicionar Tarefa"
                            Command="{Binding AddTaskCommand}"
                            BackgroundColor="#512BD4"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="48" />
                </VerticalStackLayout>
            </Border>

            <!-- Lista de Tarefas -->
            <VerticalStackLayout Padding="16,8" Spacing="0">
                <Label Text="Tarefas"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#333333"
                       Margin="0,0,0,10" />

                <CollectionView ItemsSource="{Binding FilteredTasks}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="20" HorizontalOptions="Center">
                            <Label Text="🎉"
                                   FontSize="48"
                                   HorizontalOptions="Center" />
                            <Label Text="Nenhuma tarefa encontrada!"
                                   FontSize="16"
                                   TextColor="#999999"
                                   HorizontalOptions="Center"
                                   Margin="0,10,0,0" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TaskItem">
                            <SwipeView Margin="0,0,0,10">
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Excluir"
                                                   BackgroundColor="#EF4444"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveTaskCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="#E8E8E8"
                                        BackgroundColor="White"
                                        Padding="14">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <!-- Checkbox -->
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 14"
                                                Stroke="{Binding Category.Color}"
                                                BackgroundColor="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ToggleTaskCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="✓"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   IsVisible="{Binding IsCompleted}" />
                                        </Border>

                                        <!-- Conteúdo -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#333333"
                                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}" />
                                            <Label Text="{Binding Description}"
                                                   FontSize="13"
                                                   TextColor="#888888"
                                                   LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Category.Icon}"
                                                       FontSize="11" />
                                                <Label Text="{Binding Category.Name}"
                                                       FontSize="11"
                                                       TextColor="{Binding Category.Color}"
                                                       FontAttributes="Bold" />
                                                <Label Text="·"
                                                       FontSize="11"
                                                       TextColor="#CCCCCC" />
                                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM HH:mm}'}"
                                                       FontSize="11"
                                                       TextColor="#AAAAAA" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Indicador de Categoria -->
                                        <BoxView Grid.Column="2"
                                                 WidthRequest="4"
                                                 HeightRequest="40"
                                                 CornerRadius="2"
                                                 Color="{Binding Category.Color}"
                                                 VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:NullToBackgroundConverter x:Key="NullToBgConverter"
                                            xmlns:local="clr-namespace:TodoApp.Converters" />
            <local:BoolToColorConverter x:Key="BoolToColorConverter"
                                       xmlns:local="clr-namespace:TodoApp.Converters" />
            <local:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"
                                               xmlns:local="clr-namespace:TodoApp.Converters" />
        </ResourceDictionary>
    </ContentPage.Resources>

</ContentPage>
