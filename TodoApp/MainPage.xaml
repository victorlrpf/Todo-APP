<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:models="clr-namespace:TodoApp.Models"
             x:Class="TodoApp.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Registrador de Tarefas">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- HEADER -->
        <Grid Padding="20,30,20,20"
              ColumnDefinitions="*,Auto"
              BackgroundColor="#512BD4">

            <VerticalStackLayout Spacing="8">

                <Label Text="📋 Minhas Tarefas"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <HorizontalStackLayout Spacing="20">

                    <VerticalStackLayout>
                        <Label Text="{Binding TotalTasks}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Total"
                               FontSize="12"
                               TextColor="#D4C6FF"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="{Binding CompletedTasks}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#10B981"/>
                        <Label Text="Concluídas"
                               FontSize="12"
                               TextColor="#D4C6FF"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="{Binding PendingTasks}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#FFC107"/>
                        <Label Text="Pendentes"
                               FontSize="12"
                               TextColor="#D4C6FF"/>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="🌙"
                    FontSize="24"
                    WidthRequest="50"
                    HeightRequest="50"
                    CornerRadius="25"
                    BackgroundColor="#6366F1"
                    Command="{Binding ToggleThemeCommand}"
                    VerticalOptions="Start"/>

        </Grid>

        <!-- CONTEÚDO -->
        <ScrollView Grid.Row="1">

            <VerticalStackLayout Spacing="0">

                <!-- FILTROS -->
                <VerticalStackLayout Padding="16,16,16,8" Spacing="12">

                    <Label Text="Filtrar por Status"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <HorizontalStackLayout Spacing="8">

                        <Button Text="Todos"
                                Padding="12,8"
                                FontSize="12"
                                BackgroundColor="#E0E0E0"
                                TextColor="#333"
                                Command="{Binding FilterByStatusCommand}"
                                CommandParameter="{x:Null}"/>

                        <Button Text="Em Andamento"
                                Padding="12,8"
                                FontSize="12"
                                BackgroundColor="#3B82F6"
                                TextColor="White"
                                Command="{Binding FilterByStatusCommand}"
                                CommandParameter="0"/>

                        <Button Text="Concluído"
                                Padding="12,8"
                                FontSize="12"
                                BackgroundColor="#10B981"
                                TextColor="White"
                                Command="{Binding FilterByStatusCommand}"
                                CommandParameter="1"/>

                        <Button Text="Atrasado"
                                Padding="12,8"
                                FontSize="12"
                                BackgroundColor="#EF4444"
                                TextColor="White"
                                Command="{Binding FilterByStatusCommand}"
                                CommandParameter="2"/>

                    </HorizontalStackLayout>

                </VerticalStackLayout>

                <!-- NOVA TAREFA -->
                <VerticalStackLayout Padding="16,8,16,16" Spacing="8">

                    <Label Text="Nova Tarefa"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <Entry Placeholder="Nome da tarefa"
                           Text="{Binding NewTaskName}"
                           BackgroundColor="#F0F0F0"
                           Margin="0,4"/>

                    <Entry Placeholder="Descrição (opcional)"
                           Text="{Binding NewTaskDescription}"
                           BackgroundColor="#F0F0F0"
                           Margin="0,4"/>

                    <Picker Title="Selecione uma categoria"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategoryForNewTask}"
                            ItemDisplayBinding="{Binding Name}"
                            BackgroundColor="#F0F0F0"
                            Margin="0,4"/>

                    <Button Text="Adicionar Tarefa"
                            Padding="12"
                            FontSize="14"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            Command="{Binding AddTaskCommand}"/>

                </VerticalStackLayout>

                <!-- LISTA -->
                <VerticalStackLayout Padding="16,0,16,16" Spacing="8">

                    <Label Text="Tarefas"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <CollectionView ItemsSource="{Binding FilteredTasks}"
                                    SelectionMode="Single">

                        <CollectionView.ItemTemplate>

                            <DataTemplate x:DataType="models:TaskItem">

                                <SwipeView>

                                    <SwipeView.LeftItems>
                                        <SwipeItems SwipeBehaviorOnInvoked="Close">
                                            <SwipeItem Text="Concluir"
                                                       BackgroundColor="#10B981"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompleteTaskCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.LeftItems>

                                    <SwipeView.RightItems>
                                        <SwipeItems SwipeBehaviorOnInvoked="Close">
                                            <SwipeItem Text="Excluir"
                                                       BackgroundColor="#EF4444"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveTaskCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Border StrokeShape="RoundRectangle 12"
                                            Stroke="#E0E0E0"
                                            BackgroundColor="White"
                                            Padding="12"
                                            Margin="0,0,0,8">

                                        <Grid ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="12">

                                            <VerticalStackLayout Spacing="4">

                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"/>

                                                <Label Text="{Binding Description}"
                                                       FontSize="12"
                                                       Opacity="0.7"/>

                                                <HorizontalStackLayout Spacing="8">

                                                    <Label Text="{Binding Category.Icon}"
                                                           FontSize="14"/>

                                                    <Label Text="{Binding Category.Name}"
                                                           FontSize="12"
                                                           Opacity="0.7"/>

                                                    <Label Text="{Binding Status}"
                                                           FontSize="12"
                                                           Opacity="0.7"/>

                                                </HorizontalStackLayout>

                                            </VerticalStackLayout>

                                            <Button Grid.Column="1"
                                                    Grid.RowSpan="2"
                                                    Text="✓"
                                                    FontSize="20"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    CornerRadius="22"
                                                    BackgroundColor="#10B981"
                                                    TextColor="White"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeTaskStatusCommand}"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center"/>

                                        </Grid>

                                    </Border>

                                </SwipeView>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>
